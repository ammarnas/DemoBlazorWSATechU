@page "/counter"

<PageTitle>Counter</PageTitle>

<form>
    <div class="form-group">
        <label for="first-number">First Number: </label>
        <input @bind="AddClass.FirstNumber" type="number" class="form-control" id="first-number" aria-describedby="firstNumber" placeholder="Enter First Number">
    </div>
    <div class="form-group">
        <label for="second-number">Second Number: </label>
        <input @bind="AddClass.SecondNumber" type="number" class="form-control" id="first-number" aria-describedby="secondNumber" placeholder="Enter Second Number">
    </div>

    <div class="form-group">
        <label for="operation">Select Operation: </label>
        <select @bind="Operator" class="form-control" id="operation">
            <option value="+">Addition</option>
            <option value="-">Subtraction</option>
            <option value="*">Multiplication</option>
            <option value="/">Division</option>
        </select>
    </div>

    <button @onclick="Process" type="button" class="btn btn-primary">Add</button>

    <div class="form-group">
        <label for="result">Result : @AddClass.Result </label>
    </div>
</form>

